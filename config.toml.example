# RustyFile Configuration
# Copy this file to config.toml and adjust as needed.
# Environment variables prefixed with RUSTYFILE_ override these values.
# CLI arguments override everything.

# Network settings
host = "0.0.0.0"
port = 8080

# File system root to browse
root = "./data"

# Internal data directory (database, etc.)
data_dir = "./rustyfile-data"

# Logging
log_level = "info"       # trace, debug, info, warn, error
log_format = "pretty"    # "pretty" or "json"

# Authentication
jwt_expiry_hours = 2
min_password_length = 10

# Setup wizard timeout (minutes)
setup_timeout_minutes = 5

# CORS origins (comma-separated, or "*" for any)
# WARNING: "*" allows all origins — set explicit origins in production.
# cors_origins = "https://example.com,https://app.example.com"

# Trusted proxy IPs for X-Forwarded-For (comma-separated).
# Empty = trust all (development default). Set to reverse proxy IPs in production.
# trusted_proxies = "127.0.0.1,10.0.0.1"
